{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "api/index.js"
    },
    {
      "source": "/pokemons(.*)",
      "destination": "api/index.js"
    },
    {
      "source": "/types(.*)",
      "destination": "api/index.js"
    },
    {
      "source": "/addpokemon(.*)",
      "destination": "api/index.js"
    },
    {
      "source": "/delete/(.*)",
      "destination": "api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "client/$1"
    }
  ]
}
